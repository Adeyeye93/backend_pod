# Copy this file to /opt/pod/.env on the server and fill in all values.
# Never commit the real .env file to git.

# ---- Phoenix ----------------------------------------------------------------
PHX_SERVER=true
PHX_HOST=YOUR_EC2_PUBLIC_IP     # e.g. 3.92.45.10 — no http:// prefix
PORT=4000
PHX_SCHEME=http
PHX_URL_PORT=80

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=REPLACE_WITH_64_CHAR_SECRET

# ---- Database ---------------------------------------------------------------
# Format: ecto://USER:PASSWORD@HOST/DATABASE
DATABASE_URL=ecto://pod:verySecure@localhost/pod_prod
POOL_SIZE=10

# ---- Guardian JWT -----------------------------------------------------------
# Generate with: mix guardian.gen.secret
GUARDIAN_SECRET_KEY=REPLACE_WITH_GUARDIAN_SECRET

# ---- AWS S3 -----------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# ---- RTMP -------------------------------------------------------------------
RTMP_BASE_URL=rtmp://YOUR_EC2_PUBLIC_IP:1935/live
